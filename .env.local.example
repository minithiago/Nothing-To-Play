# Optional overrides for local development.
# VITE_TEXTURES_BASE_URL / VITE_FILM_INFO_BASE_URL only need to be set if you
# want to point at an external CDN — by default they're derived from Vite's
# base path automatically (see app/vf/config/media/media.ts and
# app/vf/utils/films.ts), which keeps things working on any deployment target.
# VITE_TEXTURES_BASE_URL=/media
# VITE_FILM_INFO_BASE_URL=/json
VITE_EXPERIMENTAL_MEDIA_VERSION_3_ENABLED=1
VITE_COMPRESS_GLSL=
VITE_ANALYZE_BUNDLE=
